    <PkgBepInEx_Core Condition=" '$(PkgBepInEx_Core)' == '' ">C:\Users\bigma\.nuget\packages\bepinex.core\5.4.21</PkgBepInEx_Core>
    <PkgBepInEx_Analyzers Condition=" '$(PkgBepInEx_Analyzers)' == '' ">C:\Users\bigma\.nuget\packages\bepinex.analyzers\1.0.8</PkgBepInEx_Analyzers>
